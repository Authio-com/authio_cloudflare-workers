{
  "name": "@useauthio/cloudflare-workers",
  "version": "0.2.0",
  "description": "Authio session verification for Cloudflare Workers, with JWKS caching in CF KV.",
  "license": "MIT",
  "author": "Authio",
  "repository": {
    "type": "git",
    "url": "https://github.com/Authio-com/authio_cloudflare-workers.git"
  },
  "homepage": "https://authio.com",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.8.71",
    "@cloudflare/workers-types": "^4.20260613.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "~3.2.0"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.28.1"
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-36p8-mvp6-cv38"
      ]
    }
  }
}
